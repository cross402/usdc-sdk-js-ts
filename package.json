{
  "name": "@cross402/usdc",
  "version": "0.2.0",
  "description": "TypeScript client for the Agent Tech v2 payment API",
  "author": "paul-agent <paul@agent.tech>",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/esm/server.d.ts",
        "default": "./dist/esm/server.js"
      },
      "require": {
        "types": "./dist/cjs/server.d.ts",
        "default": "./dist/cjs/server.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/esm/browser.d.ts",
        "default": "./dist/esm/browser.js"
      },
      "require": {
        "types": "./dist/cjs/browser.d.ts",
        "default": "./dist/cjs/browser.js"
      }
    }
  },
  "bin": {
    "cross402-usdc": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "lint": "biome lint",
    "check": "biome check"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cross402/usdc-sdk-js-ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@types/bun": "^1.3.9",
    "camelcase-keys": "^10.0.2",
    "zod": "^3.23.0",
    "commander": "^12.1.0",
    "decamelize-keys": "^2.0.1"
  },
  "sideEffects": false
}
